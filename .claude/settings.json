{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Write",
          "file_paths": [
            "backend/**/*.py"
          ]
        },
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && ruff check ${file} --fix && echo '[Hook] ruff: OK'"
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "file_paths": [
            "backend/**/*.py"
          ]
        },
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && ruff check ${file} --fix && echo '[Hook] ruff: OK'"
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Write",
          "file_paths": [
            "frontend/src/**/*.ts",
            "frontend/src/**/*.tsx"
          ]
        },
        "hooks": [
          {
            "type": "command",
            "command": "cd frontend && npx eslint ${file} --fix && echo '[Hook] eslint: OK'"
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "file_paths": [
            "frontend/src/**/*.ts",
            "frontend/src/**/*.tsx"
          ]
        },
        "hooks": [
          {
            "type": "command",
            "command": "cd frontend && npx eslint ${file} --fix && echo '[Hook] eslint: OK'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__jira__jira_get_project_issues",
      "mcp__jira__jira_get_sprints_from_board",
      "mcp__github__list_pull_requests",
      "Bash(git checkout:*)",
      "mcp__jira__jira_get_transitions",
      "mcp__jira__jira_transition_issue",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "mcp__github__create_pull_request",
      "mcp__jira__jira_create_remote_issue_link",
      "mcp__jira__jira_create_sprint",
      "mcp__confluence__confluence_get_page_children",
      "mcp__confluence__confluence_create_page",
      "mcp__confluence__confluence_update_page"
    ]
  }
}
